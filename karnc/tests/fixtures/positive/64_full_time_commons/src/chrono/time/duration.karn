commons chrono.time

---
A length of time in milliseconds. Can be negative (representing past intervals).
---
type Duration = opaque Int

fn Duration.zero() -> Duration {
  Duration.unsafe(0)
}

fn Duration.isPositive(self) -> Bool {
  self.raw > 0
}

fn Duration.isZero(self) -> Bool {
  self.raw == 0
}
