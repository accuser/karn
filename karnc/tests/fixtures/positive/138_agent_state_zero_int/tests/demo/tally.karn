---
State-init probe: a never-seen Int field reads 0.
---
test demo.tally

test "a fresh Tally key reads count as 0" {
	match TallyId.of("fresh") {
		Err(_) => assert false
		Ok(id) => {
			let reading <- read.call(id)
			match reading {
				Ok(n)  => assert n == 0
				Err(_) => assert false
			}
		}
	}
}
