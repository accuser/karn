---
State-init probe: a never-seen Option field reads None (so resolve fails Empty).
---
test demo.slot

test "a fresh Slot key resolves to Empty" {
	match Label.of("fresh") {
		Err(_) => assert false
		Ok(id) => {
			let outcome <- resolve.call(id)
			match outcome {
				Ok(_)  => assert false
				Err(slotError) => match slotError {
					Empty => assert true
				}
			}
		}
	}
}
