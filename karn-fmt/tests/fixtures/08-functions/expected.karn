context demo.functions

capability Logger {
	fn log(message: String) -> Effect[()]
}

fn add(a: Int, b: Int) -> Int { a + b }

fn map[A, B](xs: List[A], f: A -> B) -> List[B] { [] }

type Counter = { count: Int }

fn Counter.increment(self) -> Counter { Counter { count: self.count + 1 } }

fn combine(
	first: String,
	second: String,
	third: String,
	fourth: String,
	fifth: String,
	sixth: String,
	seventh: String
) -> String { first }

service announce {
	on call(message: String) -> Effect[()] given Logger {
		let _ <- Logger.log(message)
		Effect.pure(())
	}
}

---
Add three integers together.
---
fn add3(a: Int, b: Int, c: Int) -> Int { a + b + c }
