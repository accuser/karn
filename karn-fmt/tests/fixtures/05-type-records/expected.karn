commons records {
	type Empty = {}

	type Point = { x: Int, y: Int }

	type Profile = { name: String, email: String, age: Int, active: Bool, nickname: String }

	type Span = { start: Int where Positive, end: Int where NonNegative }

	type Address = {
		line1: String,
		line2: String,
		city: String,
		region: String,
		postcode: String,
		country: String,
	}
}
