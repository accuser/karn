{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Bynk",
  "scopeName": "source.bynk",
  "fileTypes": ["bynk"],
  "patterns": [
    { "include": "#doc-block" },
    { "include": "#line-comment" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "doc-block": {
      "name": "comment.block.documentation.bynk",
      "begin": "^\\s*---+\\s*$",
      "end": "^\\s*---+\\s*$",
      "patterns": []
    },
    "line-comment": {
      "name": "comment.line.double-dash.bynk",
      "match": "--.*$"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.bynk",
          "match": "\\b(commons|context|adapter|binding|test|integration|wires|type|fn|capability|provides|service|agent|actor|state|invariant|exports|uses|consumes|mocks|protocol)\\b"
        },
        {
          "comment": "`key` and `store` are CONTEXTUAL keywords (like in the parser): they introduce an agent field only in `<kw> <name>:` position, so they stay an ordinary identifier elsewhere (a `store`/`key` function parameter, a `cache.store` context). The look-ahead requires a following `<name>:` (whitespace + identifier + colon), which a parameter `store: Int` (colon adjacent) and a member `cache.store` do not match.",
          "name": "keyword.declaration.bynk",
          "match": "\\b(key|store)\\b(?=\\s+[A-Za-z_][A-Za-z0-9_]*\\s*:)"
        },
        {
          "name": "keyword.control.bynk",
          "match": "\\b(if|else|let|match|is|commit|on|given|call|by|as|assert|expect|from|http|cron|queue|schedule|message)\\b"
        },
        {
          "name": "variable.language.self.bynk",
          "match": "\\bself\\b"
        },
        {
          "name": "keyword.other.http-method.bynk",
          "match": "\\b(GET|POST|PUT|PATCH|DELETE)\\b"
        },
        {
          "name": "keyword.modifier.bynk",
          "match": "\\b(opaque|transparent)\\b"
        },
        {
          "name": "keyword.operator.bynk",
          "match": "\\b(where|and|implies|enum|record)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.bynk",
          "match": "\\b(Int|String|Bool|Float|Result|Option|Effect|ValidationError|JsonError|HttpResult|List|Map)\\b"
        },
        {
          "name": "support.function.predicate.bynk",
          "match": "\\b(Matches|InRange|MinLength|MaxLength|Length|NonNegative|Positive|NonEmpty)\\b"
        },
        {
          "name": "entity.name.type.bynk",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.bynk",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.bynk", "match": "\\\\[nt\"\\\\]" },
        { "include": "#interpolation" }
      ]
    },
    "interpolation": {
      "comment": "A `\\(expr)` interpolation hole (v0.43). The escape `\\\\[nt\"\\\\]` precedes this in #strings, so `\\\\(` (escaped backslash + paren) is a literal, not a hole.",
      "name": "meta.embedded.interpolation.bynk",
      "begin": "\\\\\\(",
      "end": "\\)",
      "beginCaptures": {
        "0": { "name": "punctuation.section.interpolation.begin.bynk" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.interpolation.end.bynk" }
      },
      "patterns": [
        { "include": "#interpolation-parens" },
        { "include": "$self" }
      ]
    },
    "interpolation-parens": {
      "comment": "Balances nested parens inside a hole so the outer `\\)` only closes on the matching `)` (e.g. `\\(f(x))`).",
      "begin": "\\(",
      "end": "\\)",
      "patterns": [
        { "include": "#interpolation-parens" },
        { "include": "$self" }
      ]
    },
    "numbers": {
      "name": "constant.numeric.bynk",
      "match": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b"
    },
    "builtins": {
      "comment": "Capitalised builtins must precede #types so the generic entity.name.type rule does not shadow them.",
      "patterns": [
        { "name": "constant.language.bynk", "match": "\\b(None)\\b" },
        {
          "name": "support.function.builtin.mock.bynk",
          "match": "\\bMock\\b(?=\\s*\\[)"
        },
        {
          "name": "support.function.builtin.bynk",
          "match": "\\b(Ok|Err|Some|Created|NoContent|BadRequest|Unauthorized|Forbidden|NotFound|Conflict|UnprocessableEntity|ServerError)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.bynk", "match": "\\b(true|false)\\b" },
        { "name": "variable.language.self.bynk", "match": "\\bself\\b" }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.bynk",
          "match": "->|<-|~>|:=|=>|==|!=|<=|>=|&&|\\|\\||\\.\\.\\.|[+\\-*/=<>!?]"
        },
        { "name": "punctuation.separator.bynk", "match": "[,;:|]" }
      ]
    },
    "identifiers": {
      "name": "variable.other.bynk",
      "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
    }
  }
}
