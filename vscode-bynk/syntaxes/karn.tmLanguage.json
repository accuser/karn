{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Karn",
  "scopeName": "source.bynk",
  "fileTypes": ["karn"],
  "patterns": [
    { "include": "#doc-block" },
    { "include": "#line-comment" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "doc-block": {
      "name": "comment.block.documentation.karn",
      "begin": "^\\s*---+\\s*$",
      "end": "^\\s*---+\\s*$",
      "patterns": []
    },
    "line-comment": {
      "name": "comment.line.double-dash.karn",
      "match": "--.*$"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.karn",
          "match": "\\b(commons|context|adapter|binding|test|integration|wires|type|fn|capability|provides|service|agent|state|exports|key|uses|consumes|mocks)\\b"
        },
        {
          "name": "keyword.control.karn",
          "match": "\\b(if|else|let|match|is|commit|on|given|call|assert|from|http|cron|queue|schedule|message)\\b"
        },
        {
          "name": "keyword.other.http-method.karn",
          "match": "\\b(GET|POST|PUT|PATCH|DELETE)\\b"
        },
        {
          "name": "keyword.modifier.karn",
          "match": "\\b(opaque|transparent)\\b"
        },
        {
          "name": "keyword.operator.karn",
          "match": "\\b(where|and|enum|record)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.karn",
          "match": "\\b(Int|String|Bool|Float|Result|Option|Effect|ValidationError|HttpResult|List|Map)\\b"
        },
        {
          "name": "support.function.predicate.karn",
          "match": "\\b(Matches|InRange|MinLength|MaxLength|Length|NonNegative|Positive|NonEmpty)\\b"
        },
        {
          "name": "entity.name.type.karn",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.karn",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.karn", "match": "\\\\[nt\"\\\\]" },
        { "include": "#interpolation" }
      ]
    },
    "interpolation": {
      "comment": "A `\\(expr)` interpolation hole (v0.43). The escape `\\\\[nt\"\\\\]` precedes this in #strings, so `\\\\(` (escaped backslash + paren) is a literal, not a hole.",
      "name": "meta.embedded.interpolation.karn",
      "begin": "\\\\\\(",
      "end": "\\)",
      "beginCaptures": {
        "0": { "name": "punctuation.section.interpolation.begin.karn" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.interpolation.end.karn" }
      },
      "patterns": [
        { "include": "#interpolation-parens" },
        { "include": "$self" }
      ]
    },
    "interpolation-parens": {
      "comment": "Balances nested parens inside a hole so the outer `\\)` only closes on the matching `)` (e.g. `\\(f(x))`).",
      "begin": "\\(",
      "end": "\\)",
      "patterns": [
        { "include": "#interpolation-parens" },
        { "include": "$self" }
      ]
    },
    "numbers": {
      "name": "constant.numeric.karn",
      "match": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b"
    },
    "builtins": {
      "comment": "Capitalised builtins must precede #types so the generic entity.name.type rule does not shadow them.",
      "patterns": [
        { "name": "constant.language.karn", "match": "\\b(None)\\b" },
        {
          "name": "support.function.builtin.mock.karn",
          "match": "\\bMock\\b(?=\\s*\\[)"
        },
        {
          "name": "support.function.builtin.karn",
          "match": "\\b(Ok|Err|Some|Created|NoContent|BadRequest|Unauthorized|Forbidden|NotFound|Conflict|UnprocessableEntity|ServerError)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.karn", "match": "\\b(true|false)\\b" },
        { "name": "variable.language.self.karn", "match": "\\bself\\b" }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.karn",
          "match": "->|<-|=>|==|!=|<=|>=|&&|\\|\\||\\.\\.\\.|[+\\-*/=<>!?]"
        },
        { "name": "punctuation.separator.karn", "match": "[,;:|]" }
      ]
    },
    "identifiers": {
      "name": "variable.other.karn",
      "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
    }
  }
}
