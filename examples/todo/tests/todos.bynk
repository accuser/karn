suite todos

-- The `Todos` agent uses no platform capability (a storage `Map` needs no clock),
-- so `bynkc test .` constructs it by key and drives its handlers directly. A
-- list-returning handler can't be asserted on here (a `List` terminal needs a
-- typed receiver the test harness doesn't track), so the query side is covered
-- through `pendingCount`, a storage aggregate that returns a scalar.

case "add returns the item, freshly created and not done" {
  let item <- Todos("bob").add("Buy milk")
  expect item.title == "Buy milk"
  expect item.done == false
}

case "completing a known id succeeds" {
  let item    <- Todos("carol").add("Walk the dog")
  let outcome <- Todos("carol").complete(item.id)
  expect outcome is Ok(_)
}

case "completing an unknown id is NotFound" {
  let outcome <- Todos("dave").complete("nope")
  expect outcome is Err(_)
}

case "pendingCount falls as items are completed" {
  let a <- Todos("erin").add("first")
  let _ <- Todos("erin").add("second")
  let before <- Todos("erin").pendingCount()
  expect before == 2

  let _ <- Todos("erin").complete(a.id)
  let after <- Todos("erin").pendingCount()
  expect after == 1
}
