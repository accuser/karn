suite demo.shapes {
  -- v0.9.4 Part B (slice 2): bare `Val[T]` generation for sum, record, and
  -- opaque types.
  case "bare sum mock takes the first declared variant" {
    let s = Val[Status]
    expect s is Active(_)
  }

  case "bare record mock fills every field, including an opaque one" {
    let c = Val[Cart]
    expect c.count == c.count
  }
}
