---
Integration test: a service that depends on a capability another wired
context provides. The provider is instantiated locally in the consumer
(v0.15 model A1); the entry call crosses the real wire.
---
suite integration "jobs use the clock" {
  wires ops.jobs, platform.time

  case "tick reads the clock and succeeds" {
    let r <- ops.jobs.tick()
    expect r is Ok(_)
  }
}
