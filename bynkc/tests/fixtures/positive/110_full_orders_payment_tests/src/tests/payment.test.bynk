suite commerce.payment {
  mocks Logger = SilentLogger {
    fn log(msg: String) -> Effect[()] {
      ()
    }
  }

  case "authorise returns Ok for a small positive amount" {
    let result <- authorise.call(100)
    expect result is Ok(_)
  }

  case "authorise returns Err(Declined) for zero" {
    let result <- authorise.call(0)
    match result {
      Err(Declined) => { expect true }
      _             => { expect false }
    }
  }

  case "authorise returns Err(InsufficientFunds) for large amounts" {
    let result <- authorise.call(2000000)
    match result {
      Err(InsufficientFunds) => { expect true }
      _                      => { expect false }
    }
  }
}
