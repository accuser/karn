suite commerce.money {
  -- v0.9.4 Part B (slice 1): `Val[T]` for refined types in a test body.
  case "bare mock produces a default-valued quantity" {
    let d = Val[Quantity]
    expect d == d
  }

  case "pinned mock takes the given literal" {
    let q = Val[Quantity](50)
    expect q == q
  }
}
