suite integration "counter accumulates" {
  wires demo.api, demo.counter

  case "two ticks on the same id accumulate across the wire" {
    let a <- demo.api.tick("c1")
    let b <- demo.api.tick("c1")
    match b {
      Ok(n)  => expect n == 2
      Err(_) => expect false
    }
  }

  case "a fresh id starts from zero in a new case" {
    let a <- demo.api.tick("c2")
    match a {
      Ok(n)  => expect n == 1
      Err(_) => expect false
    }
  }
}
