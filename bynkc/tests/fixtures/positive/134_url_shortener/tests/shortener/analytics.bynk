suite shortener.analytics {
  case "short code rejects too-short input" {
    let result = ShortCode.fromString("ab")
    match result {
      Ok(_) => expect false
      Err(_) => expect true
    }
  }

  case "short code accepts valid input" {
    let result = ShortCode.fromString("abc123")
    match result {
      Ok(_) => expect true
      Err(_) => expect false
    }
  }

  case "long url accepts a typical url" {
    let result = LongUrl.fromString("https://example.com/path")
    expect result is Ok(_)
  }
}
