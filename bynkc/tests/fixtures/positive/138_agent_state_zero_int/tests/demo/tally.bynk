---
State-init probe: a never-seen Int field reads 0.
---
suite demo.tally

case "a fresh Tally key reads count as 0" {
	match TallyId.of("fresh") {
		Err(_) => expect false
		Ok(id) => {
			let reading <- read.call(id)
			match reading {
				Ok(n)  => expect n == 0
				Err(_) => expect false
			}
		}
	}
}
