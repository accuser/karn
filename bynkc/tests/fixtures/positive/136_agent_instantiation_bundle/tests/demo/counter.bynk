---
Tests for the counter context: instantiation + method call round-trip, and
per-key state persistence within a session.
---
suite demo.counter

case "a fresh counter reads zero" {
	match CounterId.of("c1") {
		Err(_) => expect false
		Ok(id) => {
			let total <- read.call(id)
			match total {
				Ok(n)  => expect n == 0
				Err(_) => expect false
			}
		}
	}
}

case "bumping twice accumulates" {
	match CounterId.of("c2") {
		Err(_) => expect false
		Ok(id) => {
			let _ <- bump.call(id)
			let second <- bump.call(id)
			match second {
				Ok(n)  => expect n == 2
				Err(_) => expect false
			}
		}
	}
}
