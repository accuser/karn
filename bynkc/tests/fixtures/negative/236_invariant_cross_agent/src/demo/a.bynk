context demo.a

agent Other {
  key id: String

  store n: Cell[Int]

  on call get() -> Effect[Int] {
    n
  }
}

agent Counter {
  key id: String

  store count: Cell[Int]

  invariant bad:
    Other(id).get() == count

  on call bump() -> Effect[()] {
    let cur = count
    count := cur + 1
    ()
  }
}
